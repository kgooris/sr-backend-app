{% extends 'AdminDefault/index.html.twig' %}

    {% block body %}
        <div class="col-sm-9 col-sm-offset-3 col-md-12 col-md-offset-1 main">
            <h1 class="sub-header">Festivaldagen Informatie</h1>
                <div class="table-responsive">
                <table class="table table-striped table-bordered">
                    <thead>
                    <tr>
                        <th class="col-md-1">actief</th>
                        <th class="col-md-2">datum</th>
                        <th class="col-md-1">dag</th>
                        <th class="col-md-6">info</th>
                        <th class="col-md-2"></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for festivalDag in festivalDags %}
                        <tr>
                            <td class="col-md-1" style="vertical-align: middle" align="center">{% if(festivalDag.festactive == 1) %}<span class="glyphicon glyphicon-arrow-right" aria-hidden="true"></span>{% endif %}</td>
                            <td class="col-md-2" style="vertical-align: middle" align="center">{% if festivalDag.festdate %}
                                    <a href="{{ path('admin_settings_festivaldag_show', { 'id': festivalDag.id }) }}">{{ festivalDag.festdate|date('d-m-Y') }}</a>
                                {% endif %}</td>
                            <td class="col-md-1" style="vertical-align: middle" align="center">{{ festivalDag.festday }}</td>
                            <td class="col-md-6" style="vertical-align: middle; max-width: 50px; word-wrap:break-word">{{ festivalDag.festinfo }}</td>
                            <td class="col-md-2" style="vertical-align: middle;" align="center"><a class="btn btn-default"
                                                  href="{{ path('admin_settings_festivaldag_show', { 'id': festivalDag.id }) }}">Open</a>
                                <a class="btn btn-default"
                                   href="{{ path('admin_settings_festivaldag_edit', { 'id': festivalDag.id }) }}">Pas aan</a>

                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
</div>


            <a class="btn btn-default btn-lg" href="{{ path('admin_settings_festivaldag_new') }}">Voeg Nieuwe Dag Toe</a>
            <a class="btn btn-default btn-lg" href="{{ path('admin_settings_general_edit') }}">Pas Actieve dag aan</a>
        </div>
    {% endblock %}

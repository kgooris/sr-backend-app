{% extends 'base.html.twig' %}


{% block body %}
    <br>
    <div class="jumbotron">
        <div class="container">
            <h1 align="center">Activiteiten overzicht</h1>
        </div>
    </div>
    <div class="table-responsive ">
        <table class="table table-striped table-condensed table-bordered table-hover">
            <thead>
            <tr>
                <th class="col-md-4">Status</th>
                <th class="col-md-2">Drankstand</th>
                <th class="col-md-1">SMS-bestelnr</th>
                <th class="col-md-2">Aanvraag Datum</th>
                <th class="col-md-2">Festivaldag</th>
                <th class="col-md-1"></th>

            </tr>
            </thead>
            <tbody>
            {% for order in orders %}
                <tr>
                    {% if order.ordertype.smstypeid == 21 %}
                        <td>Aanvraag hulp gevraagd voor
                        {% if order.ordernotes == "01" %}
                            vechtpartij
                        {% else %}
                            EHBO
                        {% endif %}
                        </td>
                    {% elseif order.ordertype.smstypeid == 22 %}
                        <td>Aanvraag hulp gevraagd voor
                            {% if order.ordernotes == "01" %}
                                vechtpartij
                            {% else %}
                                EHBO
                            {% endif %}<span class="glyphicon glyphicon-flash" aria-hidden="true"></span></td>
                    {% else %}

                        <td>{{ order.ordertype.beschrijving }}
                        {% if ((order.ordertype.smstypeid == 12) or (order.ordertype.smstypeid == 27) or (order.ordertype.smstypeid == 32))  %}
                            <span class="glyphicon glyphicon-flash" aria-hidden="true"></span>
                        {% endif %}
                        </td>
                    {% endif %}

                    <td>{{ order.drankstand.naam }}</td>
                    <td>{{ order.smsbestelnr }}</td>
                    <td>{% if order.createdAt %}{{ order.createdAt|date('d-m-Y H:i') }}{% endif %}</td>
                    <td>{% if order.festivaldag %}{{ order.festivaldag.festdate|date('d-m-Y') }}{% endif %}</td>
                    <td align="center">
                        <a class="btn btn-default btn-xs" href="{{ path('admin_order_show', { 'id': order.id }) }}">
                            <span class="glyphicon glyphicon-eye-open" aria-hidden="true"></span> Details
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>



{% endblock %}



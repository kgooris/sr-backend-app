{% extends 'base.html.twig' %}


{% block extramenu %}

    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-3 col-md-2 sidebar">
                <ul class="nav nav-sidebar">
                    <li class="{% if app.request.attributes.get('_route') == 'admin_homepage' %}active{% endif %}"><a
                                href="{{ path('admin_homepage') }}">Overzicht <span class="sr-only">(current)</span></a>
                    </li>
                    {% if is_granted('ROLE_NOSHOW') %}
                    <li><a href="#">Reports</a></li>
                    <li><a href="#">Analytics</a></li>
                    <li><a href="#">Export</a></li>
                    {% endif %}
                </ul>
                <h4>Acties</h4>
                <ul class="nav nav-sidebar">
                    {% if is_granted('ROLE_MAINSTOCK_ALL') %}
                        <li class="{% if app.request.attributes.get('_route') == 'admin_mainstock_index' %}active{% endif %}">
                            <a href="{{ path('admin_mainstock_index') }}">Hoofdstock Leveringen</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_BESTELLING_ALL') %}
                        <li class="{% if app.request.attributes.get('_route') == 'admin_drankbestelling_index' %}active{% endif %}">
                            <a href="{{ path('admin_drankbestelling_index') }}">Drankbestelling Beheer</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_RAPPORT_DRANKSTAND') %}
                        <li class="{% if app.request.attributes.get('_route') == 'admin_rapport_drankstanden' %}active{% endif %}">
                            <a href="{{ path('admin_rapport_drankstanden') }}">Rapport Drankstand</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_RAPPORT_INTERN') %}
                        <li class="{% if app.request.attributes.get('_route') == 'admin_rapport_intern' %}active{% endif %}">
                            <a href="{{ path('admin_rapport_intern') }}">Rapport Intern</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_RAPPORT_DRANKSTAND') %}
                        <li class="{% if app.request.attributes.get('_route') == 'admin_rapport_hoofdstocklevering' %}active{% endif %}">
                            <a href="{{ path('admin_rapport_hoofdstocklevering') }}">Rapp. Levering Hoofdstock</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_RAPPORT_DRANKSTAND') %}
                        <li class="{% if app.request.attributes.get('_route') == 'admin_rapport_stockall' %}active{% endif %}">
                            <a href="{{ path('admin_rapport_stockall') }}">Rapp. Stock inc. Eindstock</a></li>
                    {% endif %}




                </ul>

                <h4>Algemene Instellingen</h4>
                <ul class="nav nav-sidebar" style="margin-bottom: 2px;margin-top: 0px">
                    {% if is_granted('ROLE_ADMIN') %}
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_user_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_user_index') }}">Gebruikers Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_groups_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_group_index') }}">Groepen Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_role_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_role_index') }}">Rolen Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_ordertype_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_ordertype_index') }}">Order Type Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_order_index' %}active{% endif %}">
                        <a href="{{ path('admin_order_index') }}">Interne Order Systeem (DEV)</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_sms_index' %}active{% endif %}">
                        <a href="{{ path('admin_sms_inbox') }}">SMS Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_reset_orders' %}active{% endif %}">
                        <a href="{{ path('admin_settings_reset_orders') }}">Reset Orders</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_BASICADMIN') %}
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_drankstand_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_drankstand_index') }}">DrankStanden Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_dranksoort_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_dranksoort_index') }}">DrankSoorten Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_drankeenheden_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_drankeenheden_index') }}">DrankEenheden Beheer</a></li>
                    <li class="{% if app.request.attributes.get('_route') == 'admin_settings_festivaldag_index' %}active{% endif %}">
                        <a href="{{ path('admin_settings_festivaldag_index') }}">Festivaldagen Beheer</a></li>
                    {% endif %}


                </ul>

            </div>
        </div>
    </div>
    {% if app.session.started %}
        {% for flashMessage in app.session.flashbag.get('notice') %}

            <div class="col-md-offset-2 alert alert-{{ flashMessage.alert }} alert-dismissible" role="alert">
                <button type="button" class="close" data-dismiss="alert">
                    <span aria-hidden="true">&times;</span><span class="sr-only">Close</span>
                </button>
                <strong>{{ flashMessage.title }}</strong> {{ flashMessage.message }}
            </div>

        {% endfor %}
    {% endif %}
{% endblock %}




{% block body %}
    <div class="col-sm-9 col-sm-offset-3 col-md-10 col-md-offset-2 main">
        <h1 class="page-header">Dashboard</h1>
        {% set colcounter = 0 %}
        {% set rowcounter = 0 %}
        <div class="row placeholders">
        {% for drankSoort in drankSoorts %}
            {% set rowcounter = rowcounter +1 %}
            {% set colcounter = colcounter +1 %}
            {% if colcounter == 4 %}
                <div class="row placeholders">
            {% endif %}
                <div class="col-xs-3 col-sm-3 placeholder">
                    <img src="/{{ imagefolder }}/{{ drankSoort.fotopath }}" width="80" height="80"  alt="Generic placeholder thumbnail">
                    <h4>{{ drankSoort.naam }}</h4>
                    <h6>{{ drankSoort.eenheid.naam }}</h6>
                    <span class="text-muted">Stock: {{ drankSoort.stock }}</span>
                </div>

            {% if colcounter == 4 %}

                {%  set colcounter = 0 %}
                </div>
                {% if rowcounter == 1 %}
                    </div>
                {% endif %}
            {% endif %}
        {% endfor %}


    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% javascripts '@AppBundle/Resources/public/js/bootstrap-datepicker.js' filter='?yui_js' combine=true %}
    <script src="{{ asset_url }}"></script>
    {% endjavascripts %}
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {% stylesheets '@AppBundle/Resources/public/css/bootstrap-datepicker.css' combine=true %}
    <link href="{{ asset_url }}" type="text/css" rel="stylesheet">
    {% endstylesheets %}
{% endblock %}
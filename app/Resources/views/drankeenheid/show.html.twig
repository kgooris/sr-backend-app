{% extends 'AdminDefault/index.html.twig' %}

{% block body %}
 <div class="col-sm-9 col-sm-offset-3 col-md-10 col-md-offset-2 main">
    <h1>DrankEenheid</h1>

    <table>
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ drankEenheid.id }}</td>
            </tr>
            <tr>
                <th>Naam</th>
                <td>{{ drankEenheid.naam }}</td>
            </tr>
        </tbody>
    </table>

    <ul>
        <li>
            <a href="{{ path('admin_settings_drankeenheden_index') }}">Back to the list</a>
        </li>
        <li>
            <a href="{{ path('admin_settings_drankeenheden_edit', { 'id': drankEenheid.id }) }}">Edit</a>
        </li>
        <li>
            {{ form_start(delete_form) }}
                <input type="submit" value="Delete">
            {{ form_end(delete_form) }}
        </li>
    </ul>
   </div>
{% endblock %}

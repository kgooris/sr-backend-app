{% extends 'AdminDefault/index.html.twig' %}

{% block body %}
 <div class="col-sm-9 col-sm-offset-3 col-md-10 col-md-offset-2 main">
    <h1 class="sub-header">DrankEenheid list</h1>
<div class="table-responsive">
    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th>Id</th>
                <th>Naam</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for drankEenheid in drankEenheids %}
            <tr>
                <td><a href="{{ path('admin_settings_drankeenheden_show', { 'id': drankEenheid.id }) }}">{{ drankEenheid.id }}</a></td>
                <td>{{ drankEenheid.naam }}</td>
                <td>
                    <ul>
                        <li>
                            <a href="{{ path('admin_settings_drankeenheden_show', { 'id': drankEenheid.id }) }}">show</a>
                        </li>
                        <li>
                            <a href="{{ path('admin_settings_drankeenheden_edit', { 'id': drankEenheid.id }) }}">edit</a>
                        </li>
                    </ul>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <ul>
        <li>
            <a href="{{ path('admin_settings_drankeenheden_new') }}">Create a new entry</a>
        </li>
    </ul>
    </div>
    </div>
    
{% endblock %}

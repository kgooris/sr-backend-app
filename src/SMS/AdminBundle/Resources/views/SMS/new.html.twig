{% extends 'SMSAdminBundle::layout.html.twig' %}



{% block body -%}
<div class="col-sm-9 col-sm-offset-3 col-md-12 col-md-offset-1 main">
	<div class="page-header">
		<h1><i class="fa fa-envelope-o"></i> Send SMS</h1>
	</div>
<div class="swell">

		<!-- form content -->
		<div class="swell">
			<form action="{{ path('admin_sms_create') }}" method="post" {{ form_enctype(form) }} novalidate>
				<fieldset>
					{% for flashMessage in app.session.flashbag.get('error') %}
					<div class="alert alert-danger fade in">
						<button class="close" data-dismiss="alert">×</button>
						<i class="fa-fw fa fa-times"></i> <strong>{{ 'admin.flash.status.error'|trans }}</strong> {{ flashMessage }}
					</div>
					{% endfor %}
				</fieldset>
				<fieldset>
					{{ form_rest(form) }}
				</fieldset>

				<div class="form-actions">
					<footer class="col-xs-3 pull-right">
						<a class="btn btn-default btn-sm" href="{{ path('admin_sms_inbox') }}">Cancel</a>
						<button type="submit" class="btn btn-primary">Send SMS</button>
					</footer>
				</div>
			</form>
		</div>
		<!-- end form content -->

</div>
	</div>

{% endblock %}

{% extends 'SMSAdminBundle::layout.html.twig' %}





{% block body %}


    <div class="col-sm-9 col-sm-offset-3 col-md-10 col-md-offset-2 main">
    <div class="page-header">
        <h1><i class="fa fa-envelope-o"></i> Inbox
            <div class="pull-right">
                <a class="btn btn-sm btn-default" href="{{ path('admin_sms_outbox') }}">
                    Outbox <i class="fa fa-caret-down"></i>
                </a>
                <a class="btn btn-sm btn-default" href="{{ path('admin_sms_new') }}">
                    New <i class="fa fa-caret-down"></i>
                </a>
                <button class="btn btn-sm btn-default" type="button" data-toggle="collapse" data-target="#search-filter">
                    Search <i class="fa fa-caret-down"></i>
                </button>
            </div>
        </h1>
    </div>
        {% include 'SMSAdminBundle:SMS:filter-inbox.html.twig' %}
	<table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th>Number</th>
                <th>Insert Date</th>
                <th>Text</th>
                <th>Imported</th>
            </tr>
        </thead>
        <tbody>
        {% for entity in pagination %}
            <tr>

                <td>{{ entity.number }}</td>
                <td>{{ entity.insertdate == date('0000-00-00') ? "" : entity.insertdate|date('d.m.Y. H:i:s') }}</td>
                <td>{{ entity.text }}</td>
                <td class="text-center">

                    {% if (entity.imported == '1') %}
                	    <i class="fa font-xl text-success fa-check-circle-o">yes</i>

                    {% else %}
                        <i class="fa font-xl text-danger fa-dot-circle-o">no</i>

                    {% endif %}
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <div class="well well-sm well-light text-center">
    	{{ knp_pagination_render(pagination, 'SMSAdminBundle:Pagination:bootstrap.html.twig') }}
    </div>

</div>
{% endblock %}
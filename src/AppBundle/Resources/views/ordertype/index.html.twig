{% extends 'AdminDefault/index.html.twig' %}

{% block body %}
<div class="col-sm-9 col-sm-offset-3 col-md-10 col-md-offset-2 main">
    <h1 class="sub-header">OrderType list</h1>
<div class="table-responsive">
    <table class="table table-condensed table-bordered table-hover">
        <thead>
            <tr class="active">
                <th>Id</th>
                <th>Beschrijving</th>
                <th>Groep</th>
                <th>Smstype_id</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for orderType in orderTypes %}
            <tr>
                <td><a href="{{ path('admin_settings_ordertype_show', { 'id': orderType.id }) }}">{{ orderType.id }}</a></td>
                <td>{{ orderType.beschrijving }}</td>
                <td>{{ orderType.groep }}</td>
                <td>{{ orderType.smstypeid }}</td>
                <td>
                    <ul>
                        <li>
                            <a href="{{ path('admin_settings_ordertype_show', { 'id': orderType.id }) }}">show</a>
                        </li>
                        <li>
                            <a href="{{ path('admin_settings_ordertype_edit', { 'id': orderType.id }) }}">edit</a>
                        </li>
                    </ul>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <ul>
        <li>
            <a href="{{ path('admin_settings_ordertype_new') }}">Create a new entry</a>
        </li>
    </ul>
{% endblock %}

{% extends 'AdminDefault/index.html.twig' %}

{% block body %}

<div class="col-sm-9 col-sm-offset-3 col-md-10 col-md-offset-2 main">

<h2>Bestelling Details details</h2>

    <table class="table">
        <tbody>
            <tr>
                <th>DrankStand</th>
                <td>{{ order.drankstand.naam }}</td>
            </tr>
            <tr>
                <th>Toegevoegd op</th>
                <td>{% if order.createdAt %}{{ order.createdAt|date('Y-m-d H:i:s') }}{% endif %}</td>
            </tr>
            <tr>
                <th>Wachtend op levering voor</th>
                {% set difference = date("now").diff(date(order.createdAt)) %}
                {% set minutespassed = difference.i %}
                {% set hourspassed = difference.h %}
                <td>{{ hourspassed }}h:{{ minutespassed }}m</td>
            </tr>
            <tr>
                <th>Item Aangemaakt door</th>
                <td>{% if order.owner %}{{ order.owner.username }}{% endif %}</td>
            </tr>
            
        </tbody>
    </table>

	<h3>Items:</h3>
    <table class="table">
        <tbody>
            <tr>
                <th>Soort</th>
                <th>Aantal</th>
            </tr>
			{% for items in order.od %}
				<tr>
			  		<td>{{ items.drank }}</td>
			  		<td>{{ items.hoeveel }}</td>
            	</tr>
                {% endfor %}

        </tbody>
    </table>
<p>
{{ form_start(delete_form) }}
 <!--    <a class="btn btn-default btn-lg" href="{{ path('admin_drankbestelling_edit', { 'id': order.id }) }}">
                            	<span class="glyphicon glyphicon-edit" aria-hidden="true"></span> Bewerken
                            </a> -->
 <a class="btn btn-default btn-lg" href="{{ path('admin_drankbestelling_index') }}">
                            	<span class="glyphicon glyphicon-th-list" aria-hidden="true"></span> Terug naar overzicht
                            </a>
    <a class="btn btn-default btn-lg" target="_blank" href="{{ path('admin_drankbestelling_print', { 'id': order.id ,  'finalize': '0' } ) }}">
        <span class="glyphicon glyphicon-edit" aria-hidden="true"></span> Printen
    </a>
    <a class="btn btn-default btn-lg" target="_blank" href="{{ path('admin_drankbestelling_print', { 'id': order.id ,  'finalize': '1' } ) }}">
        <span class="glyphicon glyphicon-edit" aria-hidden="true"></span> Printen en bevestig
    </a>

    <a class="btn btn-default btn-lg" href="{{ path('admin_drankbestelling_levershow', { 'id': order.id }) }}">
        <span class="glyphicon glyphicon-edit" aria-hidden="true"></span> Omzetten in levering
    </a>
            <button type="submit" class="btn btn-default btn-lg" title="Levering of bestelling Verwijderen" data-placement="right" data-toggle="tooltip">
            	<span class="glyphicon glyphicon-remove" aria-hidden="true"></span> Verwijder
            </button>

            {{ form_end(delete_form) }}
 </p>
 </div>
{% endblock %}

{% block javascripts %}  
{{ parent() }}
<script>
$(function () {
	  $('[data-toggle="tooltip"]').tooltip()
	})
</script>
{% endblock %} 